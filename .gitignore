# Solana build artifacts — ignore everything under target/ EXCEPT the
# hand-written IDL, which must be committed (Anchor 0.30.1 proc-macro2
# incompat prevents auto-gen).
target/*
!target/idl
target/idl/*
!target/idl/alea_verifier.json
.anchor/
node_modules/
test-ledger/

# Keys — NEVER commit
*.json.bak
*-keypair.json
deployer*.json
target/deploy/*.json

# Private development notes
build-spec/

# Claude Code local config
.claude/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Environment
.env
.env.*

# Static-analysis byproducts
.xray/
programs/alea-verifier/programs_alea-verifier.ll

# Raw CU benchmark data — regeneratable via anchor test
validation-report-phase2-cu.json

# Subcrate cargo build outputs (root target/ already handled above with
# idl-exception; this catches per-subcrate target/ dirs that cargo-build-sbf
# and cargo fuzz produce for individual crates).
programs/*/target/
programs/*/fuzz/target/
