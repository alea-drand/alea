# Solana build artifacts — ignore everything under target/ EXCEPT the
# hand-written IDL, which must be committed (Anchor 0.30.1 proc-macro2
# incompat prevents auto-gen; see ~/vault/80-learnings/2026-04-16-
# anchor-030-proc-macro2-incompatibility.md).
target/*
!target/idl
target/idl/*
!target/idl/alea_verifier.json
.anchor/
node_modules/
test-ledger/

# Keys — NEVER commit
*.json.bak
*-keypair.json
deployer*.json
target/deploy/*.json

# Build spec (private)
build-spec/

# Claude Code (local config)
.claude/

# IDE
.vscode/
.idea/

# OS
.DS_Store

# Environment
.env
.env.*

# Monitoring (private)
scripts/collect-metrics.ts
